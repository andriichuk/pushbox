{
    "name": "andriichuk/pushbox",
    "description": "Laravel developer tool: preview FCM push payloads from notifications in the browser—Mailbook-style registry (add, to, category, variants, locales), optional DB rollback, and gated test sends.",
    "keywords": [
        "laravel",
        "laravel-package",
        "notifications",
        "fcm",
        "firebase-cloud-messaging",
        "push-notifications",
        "preview",
        "developer-tools",
        "mailbook",
        "pushbox",
        "testing"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Serhii Andriichuk",
            "email": "andriichuk29@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/view": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/notifications": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/log": "^11.0|^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "laravel-notification-channels/fcm": "Preview notifications that implement toFcm() with FcmMessage (Firebase / FCM)."
    },
    "autoload": {
        "psr-4": {
            "Andriichuk\\Pushbox\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Andriichuk\\Pushbox\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Andriichuk\\Pushbox\\PushboxServiceProvider"
            ],
            "aliases": {
                "Pushbox": "Andriichuk\\Pushbox\\Facades\\Pushbox"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "lint": "pint"
    }
}
